<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleDisplayName</key>
    <string>Port:🌍</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>portworld</string>
            </array>
        </dict>
    </array>

    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>fb-viewapp</string>
    </array>

    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Needed to connect to Meta Wearables.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>This app needs microphone access to collect audio from your glasses sessions.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>This app uses on-device speech recognition to detect the wake phrase without sending audio to a server.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>This app needs access to save photos captured from your glasses.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>This app needs local network access to connect to the Port:🌍 mock backend.</string>

    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <key>UISupportedExternalAccessoryProtocols</key>
    <array>
        <string>com.meta.ar.wearable</string>
    </array>

    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-peripheral</string>
        <string>external-accessory</string>
    </array>

    <key>MWDAT</key>
    <dict>
        <key>AppLinkURLScheme</key>
        <string>portworld://</string>
        <key>ClientToken</key>
        <string>$(CLIENT_TOKEN)</string>
        <key>MetaAppID</key>
        <string>$(META_APP_ID)</string>
        <key>TeamID</key>
        <string>$(DEVELOPMENT_TEAM)</string>
    </dict>

    <key>SON_BACKEND_BASE_URL</key>
    <string>http://127.0.0.1:8080</string>
    <key>SON_WS_PATH</key>
    <string>/ws/session</string>
    <key>SON_VISION_PATH</key>
    <string>/vision/frame</string>
    <key>SON_QUERY_PATH</key>
    <string>/query</string>
    <key>SON_API_KEY</key>
    <string></string>
    <key>SON_BEARER_TOKEN</key>
    <string></string>
    <!-- Optional explicit endpoint overrides (leave empty for baseURL+path mode) -->
    <key>SON_WS_URL</key>
    <string></string>
    <key>SON_VISION_URL</key>
    <string></string>
    <key>SON_QUERY_URL</key>
    <string></string>
    <key>SON_PHOTO_FPS</key>
    <real>1.0</real>
    <key>SON_WAKE_MODE</key>
    <string>on_device_preferred</string>
    <key>SON_WAKE_LOCALE</key>
    <string>en-US</string>
    <key>SON_WAKE_REQUIRE_ON_DEVICE</key>
    <true/>
    <key>SON_WAKE_DETECTION_COOLDOWN_MS</key>
    <integer>1500</integer>
</dict>
</plist>
